{
  "name": "career-compass-ai",
  "private": true,
  "version": "1.0.0",
  "description": "Full-stack monorepo - Frontend (Vite React) + Backend (Express API)",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run start --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run start --workspace=backend",
    "lint": "npm run lint --workspace=frontend",
    "preview": "npm run preview --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
